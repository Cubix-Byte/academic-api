{
  "name": "academy-api",
  "version": "1.0.0",
  "description": "Academy Management Microservice - Class and Subject Management",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "local": "ts-node -r tsconfig-paths/register src/server.ts",
    "debug": "node --inspect-brk=9230 -r ts-node/register -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "seed": "ts-node -r tsconfig-paths/register src/utils/seeders/classSubjectSeeder.ts",
    "db:reset": "ts-node -r tsconfig-paths/register src/utils/seeders/resetDatabase.ts",
    "db:reset-and-seed": "npm run db:reset && npm run seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "keywords": [
    "academy",
    "class",
    "subject",
    "microservice"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "shared-lib": "1.0.32",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cors": "2.8.5",
    "dotenv": "17.2.2",
    "express": "5.1.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.8",
    "socket.io": "^4.8.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "5.0.3",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^30.0.4",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  }
}
