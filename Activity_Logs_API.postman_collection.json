          "name": "Get Activity Logs (Role-Based)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{apiBase}}/activity-logs?month=August&year=2025&limit=50&offset=0",
              "host": ["{{apiBase}}"],
              "path": ["activity-logs"],
              "query": [
                {
                  "key": "userType",
                  "value": "teacher",
                  "description": "Filter by user type: 'teacher' or 'student'",
                  "disabled": true
                },
                {
                  "key": "userId",
                  "value": "",
                  "description": "Filter by specific user ID",
                  "disabled": true
                },
                {
                  "key": "classId",
                  "value": "",
                  "description": "Filter by class ID",
                  "disabled": true
                },
                {
                  "key": "subjectId",
                  "value": "",
                  "description": "Filter by subject ID",
                  "disabled": true
                },
                {
                  "key": "activityType",
                  "value": "",
                  "description": "Filter by activity type (e.g., ExamCreated, ExamCompleted)",
                  "disabled": true
                },
                {
                  "key": "month",
                  "value": "August",
                  "description": "Filter by month name (e.g., August, September)"
                },
                {
                  "key": "year",
                  "value": "2025",
                  "description": "Filter by year (e.g., 2025)"
                },
                {
                  "key": "startDate",
                  "value": "",
                  "description": "Start date (ISO format: YYYY-MM-DD)",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "",
                  "description": "End date (ISO format: YYYY-MM-DD)",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Number of results per page"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Number of results to skip"
                }
              ]
            },
            "description": "Get activity logs based on user role:\n- **School Admin**: Can see all logs (teachers + students)\n- **Teacher**: Can see class subject-wise logs and individual student logs\n- **Student**: Can only see their own logs"
          },
          "response": []
        },
