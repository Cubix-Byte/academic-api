# Database
MONGODB_URI=mongodb://localhost:27017/academy-db

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Internal API Key (for microservice communication)
# IMPORTANT: This must match the INTERNAL_API_KEY in all other microservices (user-api, etc.)
INTERNAL_API_KEY=your-internal-api-key

# User API Configuration (for microservice communication)
USER_API_URL=http://localhost:3002

# Storage API Configuration (for microservice communication)
STORAGE_API_URL=http://localhost:3004

# Base URL (for notification service - notifications-api base URL)
BASE_URL=http://localhost:3005

# Server Configuration
PORT=3002
NODE_ENV=development

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

